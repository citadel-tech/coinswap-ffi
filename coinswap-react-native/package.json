{
  "name": "coinswap-react-native",
  "version": "1.0.0",
  "description": "React Native TurboModule bindings for Coinswap",
  "author": "neoz.blockchain@gmail.com",
  "homepage": "https://github.com/Citadel-Tech/coinswap",
  "main": "src/index.ts",
  "react-native": "src/index.ts",
  "types": "src/index.ts",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/citadel-tech/coinswap-ffi.git"
  },
  "files": [
    "src",
    "ios",
    "android",
    "plugin",
    "app.plugin.js",
    "CoinswapReactNative.podspec",
    "README.md"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "jest --runInBand && npm run test:native",
    "test:live": "COINSWAP_LIVE_TESTS=1 jest tests/jest/live.*.test.ts --runInBand",
    "test:android": "bash ./tests/native/android-smoke-test.sh",
    "test:swift": "bash ./tests/native/swift-smoke-test.sh",
    "test:native": "npm run test:android && npm run test:swift",
    "ubrn:android": "ubrn build android --config ubrn.config.yaml --and-generate",
    "ubrn:ios": "IPHONEOS_DEPLOYMENT_TARGET=14.0 ubrn build ios --config ubrn.config.yaml --and-generate"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-native": ">=0.76"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^24.10.1",
    "jest": "^29.7.0",
    "react": "^18.2.0",
    "react-native": "^0.76.9",
    "ts-jest": "^29.2.5",
    "typescript": "^5.9.2",
    "uniffi-bindgen-react-native": "0.31.0-2"
  },
  "codegenConfig": {
    "name": "NativeCoinswapSpec",
    "type": "modules",
    "jsSrcsDir": "src",
    "android": {
      "javaPackageName": "org.coinswap.reactnative"
    }
  }
}
