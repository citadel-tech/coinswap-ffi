{
  "name": "coinswap-react-native",
  "version": "1.0.0",
  "description": "React Native TurboModule bindings for Coinswap",
  "main": "src/index.ts",
  "react-native": "src/index.ts",
  "types": "src/index.ts",
  "license": "MIT",
  "files": [
    "src",
    "ios",
    "android",
    "build-scripts",
    "plugin",
    "app.plugin.js",
    "CoinswapReactNative.podspec",
    "README.md"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "jest --runInBand",
    "test:live": "COINSWAP_LIVE_TESTS=1 jest __tests__/live.*.test.ts --runInBand",
    "build:android:dev": "bash ./build-scripts/development/build-dev-android-x86_64.sh",
    "build:android:release": "bash ./build-scripts/release/build-release-android-arm64_v8a.sh",
    "build:android:release:v7a": "bash ./build-scripts/release/build-release-android-armeabi-v7a.sh",
    "build:ios:dev": "bash ./build-scripts/development/build-dev-ios.sh",
    "build:ios:release": "bash ./build-scripts/release/build-release-ios.sh"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-native": ">=0.76"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^24.10.1",
    "jest": "^29.7.0",
    "react": "^18.2.0",
    "react-native": "^0.76.9",
    "ts-jest": "^29.2.5",
    "typescript": "^5.9.2"
  },
  "codegenConfig": {
    "name": "NativeCoinswapSpec",
    "type": "modules",
    "jsSrcsDir": "src",
    "android": {
      "javaPackageName": "org.coinswap.reactnative"
    }
  }
}
